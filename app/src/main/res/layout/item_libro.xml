<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/backgroundLight">

    <ImageView
        android:id="@+id/imageViewPortada"
        android:layout_width="80dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:src="@mipmap/placeholder_libro_foreground"
        android:layout_marginEnd="12dp"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">

        <TextView
            android:id="@+id/textViewTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Título del Libro"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/textViewAutor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Autor"
            android:textSize="14sp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/textViewGenero"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Género"
            android:textSize="14sp"
            android:layout_marginBottom="4dp"/>

        <!-- ✅ Nueva sección: Sinopsis -->
        <TextView
            android:id="@+id/textViewSinopsis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sinopsis del libro..."
            android:textSize="13sp"
            android:ellipsize="end"
            android:maxLines="3"
            android:layout_marginBottom="8dp"/>

        <ProgressBar
            android:id="@+id/progresoLibro"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"/>

        <TextView
            android:id="@+id/textViewPorcentaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avance: 0%"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>
</LinearLayout>
